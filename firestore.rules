rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "matandaelis@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasRequiredFields(['uid', 'name', 'email', 'role', 'createdAt']) &&
             isValidString('name', 1, 50) &&
             request.resource.data.role in ['host', 'viewer', 'admin'] &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidShow() {
      return hasRequiredFields(['title', 'hostId', 'hostName', 'isActive', 'createdAt']) &&
             isValidString('title', 1, 100) &&
             request.resource.data.hostId == request.auth.uid &&
             request.resource.data.isActive is bool &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidProduct() {
      return hasRequiredFields(['showId', 'name', 'price', 'stock', 'createdAt']) &&
             isValidString('name', 1, 100) &&
             request.resource.data.price is number && request.resource.data.price >= 0 &&
             request.resource.data.stock is number && request.resource.data.stock >= 0 &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidAuction() {
      return hasRequiredFields(['showId', 'productId', 'currentBid', 'endTime', 'isActive', 'createdAt']) &&
             request.resource.data.currentBid is number && request.resource.data.currentBid >= 0 &&
             request.resource.data.endTime is number &&
             request.resource.data.isActive is bool &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidBid() {
      return hasRequiredFields(['auctionId', 'userId', 'userName', 'amount', 'createdAt']) &&
             request.resource.data.userId == request.auth.uid &&
             request.resource.data.amount is number && request.resource.data.amount > 0 &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidMessage() {
      return hasRequiredFields(['showId', 'userId', 'userName', 'text', 'createdAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidString('text', 1, 500) &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser() && uidUnchanged() && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser() && uidNotModified() && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /shows/{showId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidShow();
      allow update: if isAuthenticated() && (request.resource.data.hostId == resource.data.hostId) && isValidShow();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProduct();
      allow update: if isAuthenticated() && isValidProduct();
    }

    match /auctions/{auctionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAuction();
      allow update: if isAuthenticated() && isValidAuction();
    }

    match /bids/{bidId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBid();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMessage();
    }
  }
}
